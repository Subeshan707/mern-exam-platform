# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://localhost:27017/exam-platform

# Auth
JWT_SECRET=replace_me
JWT_REFRESH_SECRET=replace_me_or_leave_empty

# Default admin (created on first server start if none exists)
ADMIN_EMAIL=admin@examplatform.com
ADMIN_PASSWORD=Admin@123

# Email (optional; required for password reset / notifications)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_smtp_user
EMAIL_PASS=your_smtp_password
EMAIL_FROM=no-reply@example.com
